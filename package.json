{
  "name": "speedscope",
  "version": "1.25.0",
  "description": "",
  "repository": "jlfwong/speedscope",
  "main": "index.js",
  "bin": {
    "speedscope": "./bin/cli.mjs"
  },
  "scripts": {
    "deploy": "./scripts/deploy.sh",
    "build:rust:base64-decoder": "./scripts/build-rust-base64-decoder.sh",
    "build:rust:callgrind-import": "./scripts/build-rust-callgrind-import.sh",
    "build:rust:firefox-import": "bash ./scripts/build-rust-firefox-import.sh",
    "build:rust:fuzzy-find": "./scripts/build-rust-fuzzy-find.sh",
    "build:rust:text-utils": "./scripts/build-rust-text-utils.sh",
    "build:rust:profile-search": "./scripts/build-rust-profile-search.sh",
    "build:rust:pprof-import": "./scripts/build-rust-pprof-import.sh",
    "build:rust:import-parsers": "./scripts/build-rust-import-parsers.sh",
    "build:rust:haskell-import": "./scripts/build-rust-haskell-import.sh",
    "build:rust:instruments-deep-copy": "./scripts/build-rust-instruments-deep-copy.sh",
    "build:rust:v8-prof-log": "./scripts/build-rust-v8-prof-log.sh",
    "build:rust:v8-cpu-formatter": "./scripts/build-rust-v8-cpu-formatter.sh",
    "build:rust:linux-perf": "./scripts/build-rust-linux-perf.sh",
    "prepack": "./scripts/prepack.sh --outdir \"$(pwd)/dist/release\" --protocol file",
    "prettier": "prettier --write 'src/**/*.ts' 'src/**/*.tsx'",
    "lint": "eslint 'src/**/*.ts' 'src/**/*.tsx'",
    "jest": "./scripts/test-setup.sh && jest --runInBand",
    "coverage": "npm run jest -- --coverage",
    "typecheck": "tsc --noEmit",
    "test": "./scripts/ci.sh",
    "serve": "tsx scripts/dev-server.ts",
    "perf:bench": "tsx scripts/perf/benchmark.ts",
    "perf:delegate-migration": "tsx scripts/perf/delegate-migration.ts",
    "perf:migration-status": "tsx scripts/perf/migration-status.ts",
    "perf:recursive-rust-migrate": "tsx scripts/perf/recursive-rust-migrate.ts",
    "perf:parity": "tsx scripts/perf/parity.ts",
    "perf:run": "tsx scripts/perf/run-experiment.ts",
    "perf:orchestrate": "tsx scripts/perf/cursor-orchestrator.ts"
  },
  "files": [
    "bin/cli.mjs",
    "dist/release/**",
    "!*.map"
  ],
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "22.2.3",
    "@types/jszip": "3.1.4",
    "@types/node": "14.0.1",
    "@types/pako": "1.0.0",
    "@typescript-eslint/eslint-plugin": "6.16.0",
    "@typescript-eslint/parser": "6.16.0",
    "acorn": "7.2.0",
    "aphrodite": "2.1.0",
    "esbuild": "0.27.0",
    "esbuild-jest": "0.5.0",
    "eslint": "8.0.0",
    "eslint-plugin-prettier": "5.1.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "jest": "30.2.0",
    "jest-environment-jsdom": "29.7.0",
    "jfrview": "0.2.0",
    "jsverify": "0.8.3",
    "jszip": "3.1.5",
    "pako": "1.0.6",
    "preact": "10.4.1",
    "prettier": "3.1.1",
    "protobufjs": "6.8.8",
    "source-map": "0.6.1",
    "ts-jest": "29.4.6",
    "tsx": "4.19.2",
    "typescript": "5.9.3",
    "typescript-json-schema": "0.67.0",
    "uglify-es": "3.2.2",
    "uint8array-json-parser": "0.0.2"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.tsx?$": "ts-jest",
      "^.+\\.js$": "esbuild-jest"
    },
    "transformIgnorePatterns": [],
    "setupFilesAfterEnv": [
      "./src/jest-setup.js"
    ],
    "moduleNameMapper": {
      "\\jfrview_bg.wasm$": "<rootDir>/src/import/java-flight-record.mock.ts",
      "callgrind_import_bg\\.wasm$": "<rootDir>/src/import/callgrind-rust.wasm.mock.ts",
      "firefox_import_bg\\.wasm$": "<rootDir>/src/import/firefox-rust.wasm.mock.ts",
      "fuzzy_find_bg\\.wasm$": "<rootDir>/src/lib/fuzzy-find-rust.wasm.mock.ts",
      "base64_decoder_bg\\.wasm$": "<rootDir>/src/lib/base64-decoder-rust.wasm.mock.ts",
      "text_utils_bg\\.wasm$": "<rootDir>/src/lib/text-utils-rust.wasm.mock.ts",
      "profile_search_bg\\.wasm$": "<rootDir>/src/lib/profile-search-rust.wasm.mock.ts",
      "pprof_import_bg\\.wasm$": "<rootDir>/src/import/pprof-rust.wasm.mock.ts",
      "import_parsers_bg\\.wasm$": "<rootDir>/src/import/import-parsers-rust.wasm.mock.ts",
      "instruments_deep_copy_bg\\.wasm$": "<rootDir>/src/import/instruments-deep-copy.wasm.mock.ts",
      "haskell_import_bg\\.wasm$": "<rootDir>/src/import/haskell-rust.wasm.mock.ts",
      "v8_prof_log_bg\\.wasm$": "<rootDir>/src/import/v8-prof-log-rust.wasm.mock.ts",
      "v8_cpu_formatter_bg\\.wasm$": "<rootDir>/src/import/v8cpuFormatterRust.wasm.mock.ts",
      "linux_perf_bg\\.wasm$": "<rootDir>/src/import/linux-tools-perf-rust.wasm.mock.ts"
    },
    "testRegex": "\\.test\\.tsx?$",
    "collectCoverageFrom": [
      "**/*.{ts,tsx}",
      "!**/*.d.{ts,tsx}"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ]
  },
  "dependencies": {
    "@cursor/february": "^1.0.1",
    "open": "10.1.0",
    "playwright": "^1.59.1"
  }
}
